{
  "name": "svelte-reflector",
  "version": "2.1.3",
  "description": "Reflects zod types from openAPI schemas",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "reflect": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.runtime.json && node scripts/copy-runtime.mjs",
    "typecheck:runtime": "tsc -p tsconfig.runtime.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "patch": "npm run build && npm version patch && npm publish"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": false
    }
  }
}
