        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Package" } } }
                  ]
                }
              }
            }
          }
        }
      }
