{
  "openapi": "3.0.0",
  "info": { "title": "Reflector fixture — array-root responses (non-ref item kinds)", "version": "1.0.0" },
  "paths": {
    "/arr/primitives": {
      "get": {
        "operationId": "ArrayController_primitives",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "string" } } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/arr/enums": {
      "get": {
        "operationId": "ArrayController_enums",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "string", "enum": ["ATIVO", "INATIVO"] } } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/arr/inline": {
      "get": {
        "operationId": "ArrayController_inline",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "required": ["id", "label"],
                            "properties": {
                              "id": { "type": "integer" },
                              "label": { "type": "string" }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/arr/generic": {
      "get": {
        "operationId": "ArrayController_generic",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiEnvelope": {
        "type": "object",
        "required": ["success", "message"],
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
