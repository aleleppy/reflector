{
  "openapi": "3.0.0",
  "info": { "title": "Reflector sibling-lists fixture", "version": "1.0.0" },
  "paths": {
    "/tenant/ai-chat": {
      "get": {
        "operationId": "AiChatTenantController_list",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/AiChat" } } } }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "AiChatTenantController_create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["packageId"],
                "properties": { "packageId": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/AiChat" } } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tenant/ai-chat/{chatId}/messages": {
      "get": {
        "operationId": "AiChatTenantController_getMessages",
        "parameters": [
          { "name": "chatId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/AiChatMessage" } } } }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiEnvelope": {
        "type": "object",
        "required": ["success", "message"],
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" }
        }
      },
      "AiChat": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "AiChatMessage": {
        "type": "object",
        "required": ["id", "content"],
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    }
  }
}
